# ---- Database ----
# Either set DATABASE_URL directly...
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
# ...or provide the parts (used by docker-compose to build DATABASE_URL):
DB_USER=remindarr
DB_PASSWORD=change-me
DB_NAME=remindarr
DB_SCHEMA=remindarr
# Host port to expose Postgres on locally (container is always 5432)
DB_PORT_EXTERNAL=5433

# ---- App ----
API_PORT=8000

# ---- Telegram ----
BOT_TOKEN=123456:your-bot-token
# Optional: set a webhook secret and pass it to Telegram's setWebhook
# (header X-Telegram-Bot-Api-Secret-Token). The webhook rejects spoofed calls.
TELEGRAM_WEBHOOK_SECRET=
# Optional fallback chat id (rarely needed)
CHAT_ID=

# ---- LLM gateway (natural-language parsing) ----
LLM_GATEWAY_URL=http://llmgateway:8000
LLM_GATEWAY_API_KEY=gw-your-key
LLM_GATEWAY_CHAT_PATH=/api/chat
LLM_MODEL=gemini-flash-latest

# ---- Misc ----
DEFAULT_TIMEZONE=UTC


# CREATE USER remindarr WITH PASSWORD '';

# CREATE DATABASE remindarr OWNER remindarr;

# \c remindarr

# GRANT ALL ON SCHEMA public TO remindarr;
# ALTER SCHEMA public OWNER TO remindarr;
